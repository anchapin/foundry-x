OPENCODE_SERVER_URL=http://127.0.0.1:4096

FOUNDRY_TRACE_BACKEND=sqlite
FOUNDRY_TRACE_PATH=./logs/traces.db

FOUNDRY_HARNESS_DIR=./harness
FOUNDRY_BENCHMARK_DIR=./benchmarks

# Runaway-detection caps (docs/SECURITY.md). Exceeding a cap aborts the run
# and records a task_aborted trace event. Set to 0 to disable a cap.
FOUNDRY_TASK_TIMEOUT=600
FOUNDRY_TOKEN_BUDGET=

LLAMACPP_HOST=http://127.0.0.1:8080
LLAMACPP_MODEL_PATH=/srv/models/codellama-7b.Q5_K_M.gguf

# Optional SHA256 checksum for model integrity verification (issue #284).
# When set, rocm_setup.sh --smoke-test verifies the model file matches this
# digest before launching the server. Run sha256sum on your pinned model to
# obtain the value. Leave empty to skip verification.
LLAMACPP_MODEL_SHA256=

# Model identity stamped into the trace session (issue #12) so traces are
# attributable to the model that produced them (ADR-0007 provenance). If
# unset, the runner derives a value from LLAMACPP_MODEL_PATH (basename) or
# OPENCODE_SERVER_URL (host).
FOUNDRY_MODEL_ID=
